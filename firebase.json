  });

  document.querySelectorAll("[data-leave-quiz]").forEach(btn => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.leaveQuiz || "";
      if (!confirm("本当に共同編集から脱退しますか？")) return;
