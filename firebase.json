          ${topButtonHtml()}
          <button class="ghost" id="editBtn">${canEdit() ? "編集" : "Keyを入力して編集"}</button>
        </div>
      </div>

      <div class="quiz">
        <div class="card">
          <div class="progress">
            <div>問題 ${state.quiz.index + 1} / ${state.quiz.order.length}</div>
            <div>${state.doc.items.length}問中</div>
          </div>
          <div style="height:12px"></div>
          ${q.item.section ? `<div class="sectionText">${esc(q.item.section)}</div><div style="height:10px"></div>` : ""}
          <div class="question">${esc(q.item.question)}</div>
        </div>

        <div class="card" style="display:grid;gap:10px">
          ${
            q.item.mode === "choice"
              ? renderChoiceButtons(q.item)
              : q.item.mode === "number"
                ? `
                  <div class="label">数字だけ</div>
                  <input id="answerInput" class="answer" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="数字を入力" autocomplete="off" autocapitalize="off" spellcheck="false">
                `
                : `
                  <div class="label">答え</div>
                  <input id="answerInput" class="answer" type="text" placeholder="ここに入力" autocomplete="off" autocapitalize="off" spellcheck="false">
                `
          }
          <div class="actions">
            <button class="submit" id="submitBtn">✅</button>
          </div>
        </div>
      </div>
    </div>
  `;

  document.getElementById("topBtn").addEventListener("click", () => {
    location.hash = "";
  });

  document.getElementById("editBtn").addEventListener("click", () => {
    if (canEdit()) return openEditFromDoc();
    const entered = prompt("Key を入力して編集", "");
    if (entered === null) return;
    if (state.doc.keyMode === "open") return openEditFromDoc();
    if ((entered || "").trim() === (state.doc.key || "")) {
      if (state.docId) setCookie(`qb_key_${state.docId}`, "1");
      rememberAccess(state.docId, (state.doc.key || ""), {
        title: state.doc.title || "",
        subtitle: state.doc.subtitle || "",
        createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
        updatedAt: normalizeTs(state.doc.updatedAt) || Date.now()
      });
      state.accessMode = "key";
      return openEditFromDoc();
    }
    alert("Key が違うよ");
  });

  if (q.item.mode === "choice") {
    const buttons = [...document.querySelectorAll(".choiceBtn")];
    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        state.quiz.selectedChoice = btn.dataset.choice || "";
        buttons.forEach(b => b.classList.toggle("selected", b === btn));
      });
    });
  } else {
    const input = document.getElementById("answerInput");
    input.focus();
    input.addEventListener("input", e => {
      if (q.item.mode === "number") {
        const filtered = normalizeNumberText(e.target.value);
        if (e.target.value !== filtered) e.target.value = filtered;
        state.quiz.typedAnswer = filtered;
      } else {
        state.quiz.typedAnswer = e.target.value;
      }
    });
    input.addEventListener("keydown", e => {
      if (e.key === "Enter") {
        e.preventDefault();
        submitAnswer();
      }
    });
  }

  document.getElementById("submitBtn").addEventListener("click", submitAnswer);
}

function renderResult() {
  const r = state.quiz.lastResult;
  if (!r) {
    state.quiz.phase = "question";
    render();
    return;
  }

  const q = state.doc.items[r.idx];
  document.title = state.doc.title ? `${state.doc.title} | 問題作成サイト` : "問題作成サイト";

  root.innerHTML = `
    <div class="page">
      <div class="topbar">
        <div>
          <h1 class="title">${esc(state.doc.title || "問題")}</h1>
          <div class="sub">${esc(state.doc.subtitle || "")}</div>
        </div>
        <div class="row">
          ${topButtonHtml()}
          <button class="ghost" id="editBtn">${canEdit() ? "編集" : "Keyを入力して編集"}</button>
        </div>
      </div>

      <div class="quiz">
        <div class="${r.correct ? "good" : "bad"}">${r.correct ? "正解！" : "ちがう！"}</div>

        <div class="card">
          ${q.section ? `<div class="sectionText">${esc(q.section)}</div><div style="height:10px"></div>` : ""}
          <div class="label">問題</div>
          <div class="question" style="font-size:22px">${esc(q.question)}</div>
          <div style="height:12px"></div>
          <div class="label">答え</div>
          <div class="explain">${
            q.mode === "choice"
              ? esc((q.options || []).filter(o => o.correct).map(o => o.text).join(" / "))
              : esc((q.answers || []).join(" / "))
          }</div>
          <div style="height:12px"></div>
          <div class="label">あなたの答え</div>
          <div class="explain">${esc(r.given)}</div>
        </div>

        <div class="actions">
          <button class="next" id="nextBtn">次へ</button>
        </div>
      </div>
    </div>
  `;

  document.getElementById("topBtn").addEventListener("click", () => {
    location.hash = "";
  });

  document.getElementById("editBtn").addEventListener("click", () => {
    if (canEdit()) return openEditFromDoc();
    const entered = prompt("Key を入力して編集", "");
    if (entered === null) return;
    if (state.doc.keyMode === "open") return openEditFromDoc();
    if ((entered || "").trim() === (state.doc.key || "")) {
      if (state.docId) setCookie(`qb_key_${state.docId}`, "1");
      rememberAccess(state.docId, (state.doc.key || ""), {
        title: state.doc.title || "",
        subtitle: state.doc.subtitle || "",
        createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
        updatedAt: normalizeTs(state.doc.updatedAt) || Date.now()
      });
      state.accessMode = "key";
      return openEditFromDoc();
    }
    alert("Key が違うよ");
  });

  document.getElementById("nextBtn").addEventListener("click", nextQuestion);
  enableResultEnterHandler();
}

function renderDone() {
  clearResultEnterHandler();
  const { correctCount, total } = currentScoreMeta();
  const wrongCount = state.quiz.order.filter(idx => !state.quiz.attempts[idx]?.correct).length;
  const comments = sortComments(state.doc.comments || []);

  document.title = state.doc.title ? `${state.doc.title} | 問題作成サイト` : "問題作成サイト";

  root.innerHTML = `
    <div class="page">
      <div class="topbar">
        <div>
          <h1 class="title">${esc(state.doc.title || "問題")}</h1>
          <div class="sub">${esc(state.doc.subtitle || "")}</div>
        </div>
        <div class="row">
          ${topButtonHtml()}
          <button class="ghost" id="editBtn">${canEdit() ? "編集" : "Keyを入力して編集"}</button>
        </div>
      </div>

      <div class="summary">
        <div class="card">
          <div class="score">${correctCount} / ${total} 問正解</div>
          ${state.quiz.onlyWrong ? `<div class="note" style="margin-top:10px">間違えた問題だけのやり直しだよ。</div>` : `<div class="note" style="margin-top:10px">もう一回やり直せるよ。</div>`}
        </div>

        <div class="actions" style="justify-content:flex-start">
          <button class="primary" id="restartBtn">もう一度！</button>
          <button class="ghost" id="commentsBtn">${esc(commentButtonLabel(comments))}</button>
          ${wrongCount > 0 && !state.quiz.onlyWrong ? `<button class="ghost" id="wrongOnlyBtn">間違えた問題だけやり直す</button>` : ``}
        </div>

        ${state.showComments ? renderCommentsPanel(comments) : ""}

        <div class="card">
          <div class="label">全問題と答え</div>
          <div class="reviewList">
            ${state.doc.items.map(item => `
              <div class="reviewItem">
                ${item.section ? `<div class="reviewSection">${esc(item.section)}</div>` : ""}
                <div class="reviewQ">${esc(item.question)}</div>
                <div class="reviewA">${
                  item.mode === "choice"
                    ? esc((item.options || []).filter(o => o.correct).map(o => o.text).join(" / "))
                    : esc((item.answers || []).join(" / "))
                }</div>
              </div>
            `).join("")}
          </div>
        </div>
      </div>
    </div>
  `;

  document.getElementById("topBtn").addEventListener("click", () => {
    location.hash = "";
  });

  document.getElementById("editBtn").addEventListener("click", () => {
    if (canEdit()) return openEditFromDoc();
    const entered = prompt("Key を入力して編集", "");
    if (entered === null) return;
    if (state.doc.keyMode === "open") return openEditFromDoc();
    if ((entered || "").trim() === (state.doc.key || "")) {
      if (state.docId) setCookie(`qb_key_${state.docId}`, "1");
      rememberAccess(state.docId, (state.doc.key || ""), {
        title: state.doc.title || "",
        subtitle: state.doc.subtitle || "",
        createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
        updatedAt: normalizeTs(state.doc.updatedAt) || Date.now()
      });
      state.accessMode = "key";
      return openEditFromDoc();
    }
    alert("Key が違うよ");
  });

  document.getElementById("restartBtn").addEventListener("click", restartQuiz);

  const commentsBtn = document.getElementById("commentsBtn");
  if (commentsBtn) commentsBtn.addEventListener("click", openCommentToggle);

  const wrongOnlyBtn = document.getElementById("wrongOnlyBtn");
  if (wrongOnlyBtn) wrongOnlyBtn.addEventListener("click", startWrongOnlyQuiz);

  if (state.showComments) {
    const commentName = document.getElementById("commentName");
    const commentText = document.getElementById("commentText");
    const commentPrivate = document.getElementById("commentPrivate");
    const postCommentBtn = document.getElementById("postCommentBtn");
    const suggestionPanel = document.getElementById("commentSuggestionPanel");

    const refreshSuggestions = () => {
      if (!suggestionPanel || !commentText) return;
      const cursor = commentText.selectionStart ?? commentText.value.length;
      const ctx = analyzeComposerTrigger(commentText.value, cursor);
      const suggestions = getComposerSuggestions(ctx);

      if (!ctx || !suggestions.length) {
        suggestionPanel.innerHTML = "";
        suggestionPanel.classList.add("hide");
        return;
      }

      suggestionPanel.classList.remove("hide");
      suggestionPanel.innerHTML = `
        <span class="suggestionLabel">${ctx.trigger === "@" ? "@" : "#"}</span>
        ${suggestions.map(s => `<button type="button" class="suggestionChip" data-suggest="${esc(s.insert)}">${esc(s.label)}</button>`).join("")}
      `;

      [...suggestionPanel.querySelectorAll("[data-suggest]")].forEach(btn => {
        btn.addEventListener("click", () => {
          insertComposerText(commentText, btn.dataset.suggest || "", ctx);
          state.commentDraft.text = commentText.value;
          commentText.style.height = "auto";
          commentText.style.height = `${Math.max(120, commentText.scrollHeight)}px`;
          refreshSuggestions();
        });
      });
    };

    if (commentName) {
      commentName.addEventListener("input", e => {
        state.commentDraft.name = e.target.value;
        setCommentName(e.target.value.trim() || "匿名");
      });
    }

    if (commentText) {
      commentText.addEventListener("input", e => {
        state.commentDraft.text = e.target.value;
        e.target.style.height = "auto";
        e.target.style.height = `${Math.max(120, e.target.scrollHeight)}px`;
        refreshSuggestions();
      });
      commentText.addEventListener("keyup", refreshSuggestions);
      commentText.addEventListener("click", refreshSuggestions);
      commentText.addEventListener("focus", refreshSuggestions);
      commentText.style.height = "auto";
      commentText.style.height = `${Math.max(120, commentText.scrollHeight)}px`;
      refreshSuggestions();
    }

    if (commentPrivate) {
      commentPrivate.addEventListener("change", e => {
        state.commentDraft.isPrivate = !!e.target.checked;
      });
    }

    if (postCommentBtn) postCommentBtn.addEventListener("click", addComment);

    document.querySelectorAll("[data-toggle-comment]").forEach(btn => {
      btn.addEventListener("click", () => toggleCommentVisibility(btn.dataset.toggleComment || ""));
    });
    document.querySelectorAll("[data-delete-comment]").forEach(btn => {
      btn.addEventListener("click", () => deleteComment(btn.dataset.deleteComment || ""));
    });
  }
}

function renderLoading() {
  clearResultEnterHandler();
  document.title = "読み込み中 | 問題作成サイト";
  root.innerHTML = `
    <div class="page">
      <div class="hero">
        <div class="card">
          <h1 style="margin:0">読み込み中…</h1>
          <p style="margin:12px 0 0;color:var(--muted)">Firestore からデータを取ってるよ。</p>
        </div>
      </div>
    </div>
  `;
}

function render() {
  if (state.screen === "loading") return renderLoading();
  if (state.screen === "home") return renderHome();
  if (state.screen === "editor") return renderEditor();

  if (state.screen === "quiz") {
    if (!state.doc || !state.doc.items || !state.doc.items.length) {
      state.screen = "home";
      return render();
    }
    if (state.quiz.phase === "question") return renderQuestion();
    if (state.quiz.phase === "result") return renderResult();
    if (state.quiz.phase === "done") return renderDone();
  }
}

async function openEditRoute(id) {
  state.screen = "loading";
  render();

  try {
    const snap = await getDoc(doc(db, COLLECTION, id));
    if (!snap.exists()) {
      state.screen = "home";
      render();
      return;
    }

    const data = snap.data() || {};
    const parsed = data.rawText
      ? parseQuizText(data.rawText)
      : {
          items: Array.isArray(data.items) ? data.items : [],
          globalSettings: data.globalSettings || defaultGlobalSettings()
        };

    state.docId = id;
    state.doc = {
      title: data.title || "問題",
      subtitle: data.subtitle || "",
      rawText: data.rawText || reconstructRawTextFromItems(parsed.items || [], parsed.globalSettings || defaultGlobalSettings()),
      items: parsed.items || [],
      globalSettings: data.globalSettings || parsed.globalSettings || defaultGlobalSettings(),
      keyMode: data.keyMode || "key",
      key: data.key || "",
      ownerToken: data.ownerToken || "",
      slug: data.slug || id,
      createdAt: data.createdAt || null,
      updatedAt: data.updatedAt || null,
      comments: sortComments(Array.isArray(data.comments) ? data.comments : [])
    };

    setAccessModeForDoc(state.doc, id);

    if (state.accessMode === "key") {
      rememberAccess(id, state.doc.key, {
        title: state.doc.title || "",
        subtitle: state.doc.subtitle || "",
        createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
        updatedAt: normalizeTs(state.doc.updatedAt) || Date.now()
      });
      openEditFromDoc();
      return;
    }

    if (state.accessMode === "owner" || state.accessMode === "open") {
      openEditFromDoc();
      return;
    }

    const entered = prompt("Key を入力して編集", "");
    if (entered === null) {
      location.hash = `#/${encodeURIComponent(id)}`;
      return;
    }

    if ((entered || "").trim() === (state.doc.key || "")) {
      if (state.docId) setCookie(`qb_key_${state.docId}`, "1");
      rememberAccess(state.docId, (state.doc.key || ""), {
        title: state.doc.title || "",
        subtitle: state.doc.subtitle || "",
        createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
        updatedAt: normalizeTs(state.doc.updatedAt) || Date.now()
      });
      state.accessMode = "key";
      openEditFromDoc();
    } else {
      alert("Key が違うよ");
      location.hash = `#/${encodeURIComponent(id)}`;
    }
  } catch (err) {
    console.error(err);
    state.screen = "home";
    render();
  }
}

async function loadRoute() {
  applySystemTheme();
  const r = route();

  if (r.name === "home") {
    state.screen = "home";
    state.showComments = false;
    render();
    return;
  }

  if (r.name === "create") {
    state.doc = null;
    state.docId = "";
    state.accessMode = "none";
    state.draft = blankDraft();
    state.showComments = false;
    render();
    return;
  }

  if (r.name === "edit") {
    await openEditRoute(r.id);
    return;
  }

  if (r.name === "quiz") {
    state.screen = "loading";
    state.showComments = false;
    render();

    try {
      const snap = await getDoc(doc(db, COLLECTION, r.id));
      if (!snap.exists()) {
        state.screen = "home";
        render();
        return;
      }

      const data = snap.data() || {};
      const parsed = data.rawText
        ? parseQuizText(data.rawText)
        : {
            items: Array.isArray(data.items) ? data.items : [],
            globalSettings: data.globalSettings || defaultGlobalSettings()
          };

      startQuiz({
        title: data.title || "問題",
        subtitle: data.subtitle || "",
        rawText: data.rawText || reconstructRawTextFromItems(parsed.items || [], parsed.globalSettings || defaultGlobalSettings()),
        items: parsed.items || [],
        globalSettings: data.globalSettings || parsed.globalSettings || defaultGlobalSettings(),
        keyMode: data.keyMode || "key",
        key: data.key || "",
        ownerToken: data.ownerToken || "",
        slug: data.slug || r.id,
        createdAt: data.createdAt || null,
        updatedAt: data.updatedAt || null,
        comments: sortComments(Array.isArray(data.comments) ? data.comments : [])
      }, r.id);
    } catch (err) {
      console.error(err);
      state.screen = "home";
      render();
    }
  }
}

if (systemDark) {
  const onThemeChange = () => {
    applySystemTheme();
    render();
  };
  if (systemDark.addEventListener) {
    systemDark.addEventListener("change", onThemeChange);
  } else if (systemDark.addListener) {
    systemDark.addListener(onThemeChange);
  }
}

window.addEventListener("hashchange", loadRoute);
loadRoute();
