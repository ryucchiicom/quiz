    });
  });

  document.querySelectorAll("[data-edit-quiz]").forEach(btn => {
    btn.addEventListener("click", () => {
      location.hash = `#/edit/${encodeURIComponent(btn.dataset.editQuiz || "")}`;
    });
  });

  document.querySelectorAll("[data-copy-quiz]").forEach(btn => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.copyQuiz || "";
      const link = prettyLink(id);
      try {
        await navigator.clipboard.writeText(link);
        alert("リンクをコピーしたよ");
      } catch {
        prompt("コピーできない環境だったよ。手動でコピーしてね", link);
      }
