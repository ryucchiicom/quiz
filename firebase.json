function renderEditor() {
  clearResultEnterHandler();
  const d = state.draft || blankDraft();
  document.title = "作成 / 編集 | 問題作成サイト";

  root.innerHTML = `
    <div class="page">
      <div class="topbar">
        <div>
          <h1 class="title">作成 / 編集</h1>
          <div class="sub">タイトルの右に Key ボタン</div>
        </div>
        <div class="row">
          ${topButtonHtml()}
        </div>
      </div>

      <div class="card" style="display:grid;gap:14px">
        <div class="row">
          <div style="flex:1;min-width:220px">
            <div class="label">タイトル</div>
            <input id="titleInput" class="input" type="text" placeholder="タイトル" value="${esc(d.title)}">
          </div>
          <button class="ghost" id="keyBtn" style="height:48px;align-self:end">Key</button>
        </div>

        <div>
          <div class="label">サブタイトル</div>
          <input id="subInput" class="input" type="text" placeholder="サブタイトル" value="${esc(d.subtitle)}">
        </div>

        <div class="row" style="justify-content:space-between;align-items:center;">
          <div id="editorInfo" class="note"></div>
          <div class="row" style="justify-content:flex-end;">
            ${editorActionHtml()}
          </div>
        </div>

        <div>
          <div class="label">問題欄</div>
          <div class="gridEditor">
            <div id="gutter" class="gutter"></div>
            <textarea id="problemText" class="textarea" wrap="off" spellcheck="false" placeholder="例:
[random] [choice]
日本について
首都=東京
[choice] 2+2=4,!(または＊)5
[number] 1+1=2
[game start online] start time:8/15/20/00 think time:30 time bonus:100
">${esc(d.rawText)}</textarea>
          </div>
          <div class="help">
            1行目に全体タグ。<br>
            個別設定は <b>[choice] A=B,!(または＊)C</b> / <b>[number] 123=123</b>。<br>
            コメント欄では <b>@</b> で点数、<b>#</b> でタグ候補が出るよ。
          </div>
        </div>
      </div>
    </div>
  `;

  const titleInput = document.getElementById("titleInput");
  const subInput = document.getElementById("subInput");
  const problemText = document.getElementById("problemText");
  const gutter = document.getElementById("gutter");
  const keyBtn = document.getElementById("keyBtn");
  const saveBtn = document.getElementById("saveBtn");
  const deleteBtn = document.getElementById("deleteBtn");
  const leaveBtn = document.getElementById("leaveBtn");
  const topBtn = document.getElementById("topBtn");
  const editorInfo = document.getElementById("editorInfo");

  function refreshKeyStatus() {
    if (!state.doc) {
      editorInfo.textContent = d.keyMode === "open"
        ? "Key: open（誰でも編集）"
        : (d.key ? "Key: 設定済み" : "Key: 未設定");
      keyBtn.disabled = false;
      keyBtn.textContent = "Key";
      return;
    }

    if (isOwner()) {
      editorInfo.textContent = d.keyMode === "open"
        ? "Key: open（誰でも編集）"
        : (d.key ? "Key: 設定済み" : "Key: 未設定");
      keyBtn.disabled = false;
      keyBtn.textContent = "Key";
      keyBtn.title = "";
    } else {
      editorInfo.textContent = state.doc.keyMode === "open"
        ? "公開編集モード"
        : "Keyは主催者のみ変更できます";
      keyBtn.disabled = true;
      keyBtn.textContent = "Key";
      keyBtn.title = "Keyは主催者のみ変更できます";
    }
  }

  titleInput.addEventListener("input", e => d.title = e.target.value);
  subInput.addEventListener("input", e => d.subtitle = e.target.value);
  problemText.addEventListener("input", e => {
    d.rawText = e.target.value;
    syncEditorArea(problemText, gutter);
  });

  keyBtn.addEventListener("click", () => {
    if (state.doc && !isOwner()) return;

    const cur = d.keyMode === "open" ? "open" : (d.key || "");
    const next = prompt("Key を入力。open で誰でも編集。", cur);
    if (next === null) return;
    const v = next.trim();
    if (!v) {
      d.keyMode = "key";
      d.key = "";
    } else if (v.toLowerCase() === "open") {
      d.keyMode = "open";
      d.key = "";
    } else {
      d.keyMode = "key";
      d.key = v;
    }
    refreshKeyStatus();
  });

  if (topBtn) {
    topBtn.addEventListener("click", () => {
      location.hash = "";
    });
  }

  if (saveBtn) {
    saveBtn.addEventListener("click", async () => {
      const title = d.title.trim();
      const subtitle = d.subtitle.trim();
      const parsed = parseQuizText(d.rawText);
      const items = parsed.items;

      if (!title) return alert("タイトルを入れてね");
      if (!items.length) return alert("問題が1つも読めなかったよ。");

      const newId = slugify(title);
      const oldId = state.docId || "";
      const isExisting = !!state.doc;
      const ownerToken = isExisting ? (state.doc.ownerToken || getCookie(OWNER_COOKIE) || uid()) : (getCookie(OWNER_COOKIE) || uid());
      if (!isExisting) setCookie(OWNER_COOKIE, ownerToken);

      const canChangeKey = !state.doc || isOwner();
      const effectiveKeyMode = canChangeKey ? d.keyMode : (state.doc?.keyMode || "key");
      const effectiveKey = canChangeKey ? (d.keyMode === "open" ? "" : d.key) : (state.doc?.key || "");
      const existingCreatedAt = normalizeTs(state.doc?.createdAt) || Date.now();
      const existingComments = Array.isArray(state.doc?.comments) ? state.doc.comments : [];

      const payload = {
        title,
        subtitle,
        rawText: d.rawText,
        items,
        globalSettings: parsed.globalSettings,
        keyMode: effectiveKeyMode,
        key: effectiveKey,
        ownerToken,
        slug: newId,
        createdAt: existingCreatedAt,
        updatedAt: Date.now(),
        comments: existingComments
      };

      saveBtn.disabled = true;
      saveBtn.textContent = "保存中...";

      try {
        await setDoc(doc(db, COLLECTION, newId), payload, { merge: true });

        const keyChanged = !!state.doc && (
          (state.doc.keyMode || "key") !== effectiveKeyMode ||
          (effectiveKeyMode !== "open" && (state.doc.key || "") !== effectiveKey)
        );

        if (oldId && oldId !== newId) {
          try { await deleteDoc(doc(db, COLLECTION, oldId)); } catch (_) {}
          removeMyMeta(oldId);
          removeAccessRecord(oldId);
        }

        if (keyChanged && oldId === newId) {
          removeAccessRecord(newId);
        }

        state.docId = newId;
        state.doc = {
          ...payload,
          items,
          globalSettings: parsed.globalSettings,
          comments: sortComments(existingComments)
        };

        if (isOwner() || !isExisting) {
          upsertMyMeta({
            id: newId,
            title: payload.title,
            subtitle: payload.subtitle,
            createdAt: payload.createdAt,
            updatedAt: payload.updatedAt
          });
        }

        if (state.accessMode === "key") {
          rememberAccess(newId, effectiveKey, {
            title: payload.title,
            subtitle: payload.subtitle,
            createdAt: payload.createdAt,
            updatedAt: payload.updatedAt
          });
        }

        location.hash = `#/${encodeURIComponent(newId)}`;
        const link = prettyLink(newId);
        navigator.clipboard?.writeText(link).catch(() => {});
        alert(`保存したよ！\n\n${link}`);

        startQuiz(state.doc, newId);
      } catch (err) {
        console.error("save failed:", err);
        alert(`保存で失敗したよ: ${err?.message || err}`);
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = "保存";
      }
    });
  }

  if (deleteBtn) deleteBtn.addEventListener("click", openDeleteConfirmThenDelete);
  if (leaveBtn) leaveBtn.addEventListener("click", openLeaveConfirmThenLeave);

  syncEditorArea(problemText, gutter);
  refreshKeyStatus();
  titleInput.focus();
}

