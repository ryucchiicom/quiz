function uid() {
  if (crypto && crypto.randomUUID) return crypto.randomUUID().replace(/-/g, "");
  return Math.random().toString(36).slice(2) + Date.now().toString(36);
}

function slugify(text) {
  return (text || "quiz")
    .trim()
    .toLowerCase()
    .replace(/\s+/g, "-")
    .replace(/[^\p{L}\p{N}\-]+/gu, "")
    .replace(/\-+/g, "-")
    .replace(/^-+|-+$/g, "") || "quiz";
}

function esc(s) {
  return String(s ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function escBr(s) {
  return esc(s).replace(/\n/g, "<br>");
}

function norm(s) {
  return String(s ?? "")
    .replace(/\u3000/g, " ")
    .trim()
    .replace(/\s+/g, " ")
    .toLowerCase();
}

function normalizeNumberText(s) {
  return String(s ?? "").replace(/[^\d-]/g, "");
}

function splitAnswers(text) {
  return String(text ?? "")
    .split(/[、,]/)
    .map(v => v.trim())
    .filter(Boolean);
}

function extractLeadingTags(line) {
  let rest = String(line ?? "").trimStart();
  const tags = [];
  while (rest.startsWith("[")) {
    const end = rest.indexOf("]");
    if (end < 0) break;
    const tag = rest.slice(1, end).trim();
    if (!tag) break;
    tags.push(tag);
    rest = rest.slice(end + 1).trimStart();
  }
  return { tags, rest };
}

function cleanQuestionText(text) {
  return String(text ?? "")
    .replace(/\[(?:Q|\?|A|!|\*|correct)\]/gi, "")
    .trim();
}

function cleanChoiceOptionText(text) {
  return String(text ?? "")
    .replace(/\[(?:Q|\?|A|!|\*|correct)\]/gi, "")
    .replace(/^\s*(?:\[!\]|\[A\]|\[correct\]|!|\*|＊)\s*/i, "")
    .replace(/\s*(?:\[!\]|\[A\]|\[correct\]|!|\*|＊)\s*$/i, "")
    .trim();
}

function parseChoiceOptions(answerRaw) {
  const parts = String(answerRaw ?? "")
    .split(",")
    .map(v => v.trim())
    .filter(Boolean);

  const options = parts.map(part => {
    const hasCorrectMark = /(^|[\s\[])(?:\[!\]|\[A\]|\[correct\]|!|\*|＊)/i.test(part) || part.includes("[!]") || part.includes("[A]");
    let text = part.includes("=") ? part.split("=").pop().trim() : part.trim();
    text = cleanChoiceOptionText(text);
    return { text, correct: hasCorrectMark };
  }).filter(v => v.text);

  if (options.length && !options.some(v => v.correct)) {
    options[0].correct = true;
  }

  return options;
}

function defaultGlobalSettings() {
  return {
    randomOrder: false,
    responseMode: "normal", // normal | choice | number
    randomChoice: false,
    online: {
      enabled: false,
      raw: ""
    }
  };
}

function parseGlobalSettings(tags, rawConfig = "") {
  const settings = defaultGlobalSettings();
  for (const rawTag of tags) {
    const tag = String(rawTag).trim().toLowerCase();
    if (tag === "random") {
      settings.randomOrder = true;
    } else if (tag === "choice") {
      settings.responseMode = "choice";
      settings.randomChoice = false;
    } else if (tag === "random choice") {
      settings.responseMode = "choice";
      settings.randomChoice = true;
    } else if (tag === "number") {
      settings.responseMode = "number";
      settings.randomChoice = false;
    } else if (tag === "game start online") {
      settings.online.enabled = true;
    }
  }
  settings.online.raw = String(rawConfig || "").trim();
  return settings;
}

function resolveItemSettings(itemTags, globalSettings) {
  let mode = globalSettings.responseMode || "normal";
  let randomChoice = !!globalSettings.randomChoice;

  for (const rawTag of itemTags) {
    const tag = String(rawTag).trim().toLowerCase();
    if (tag === "choice") {
      mode = "choice";
      randomChoice = false;
    } else if (tag === "random choice") {
      mode = "choice";
      randomChoice = true;
    } else if (tag === "number") {
      mode = "number";
    }
  }

  return { mode, randomChoice };
}

function parseItemLine(content, itemTags, currentSection, globalSettings) {
  const eqIndex = content.search(/[=＝]/);
  if (eqIndex < 0) return null;

  const question = cleanQuestionText(content.slice(0, eqIndex).trim());
  const answerRaw = content.slice(eqIndex + 1).trim();
  if (!question) return null;

  const { mode, randomChoice } = resolveItemSettings(itemTags, globalSettings);

  if (mode === "choice") {
    const options = parseChoiceOptions(answerRaw);
    if (!options.length) return null;

    return {
      section: currentSection || "",
      question,
      mode: "choice",
      randomChoice,
      options,
      answers: options.map(o => o.text),
      tags: itemTags.slice(),
      rawLine: content
    };
  }

  if (mode === "number") {
    const answers = splitAnswers(answerRaw).map(normalizeNumberText).filter(Boolean);
    if (!answers.length) return null;

    return {
      section: currentSection || "",
      question,
      mode: "number",
      randomChoice: false,
      options: [],
      answers,
      tags: itemTags.slice(),
      rawLine: content
    };
  }

  const answers = splitAnswers(answerRaw).filter(Boolean);
  if (!answers.length) return null;

  return {
    section: currentSection || "",
    question,
    mode: "normal",
    randomChoice: false,
    options: [],
    answers,
    tags: itemTags.slice(),
    rawLine: content
  };
}

function parseQuizText(rawText) {
  const lines = String(rawText ?? "").replace(/\r/g, "").split("\n");
  const firstMeaningfulIndex = lines.findIndex(v => v.trim() !== "");
  let globalSettings = defaultGlobalSettings();
  let startIndex = 0;

  if (firstMeaningfulIndex >= 0) {
    const firstLine = lines[firstMeaningfulIndex];
    const { tags, rest } = extractLeadingTags(firstLine);

    if (tags.length && !/[=＝]/.test(rest)) {
      globalSettings = parseGlobalSettings(tags, rest);
      startIndex = firstMeaningfulIndex + 1;
    }
  }

  let currentSection = "";
  const items = [];

  for (let i = startIndex; i < lines.length; i++) {
    const raw = lines[i];
    if (!raw.trim()) continue;

    const { tags, rest } = extractLeadingTags(raw);
    const content = rest.trim();
    if (!content) continue;

    if (!/[=＝]/.test(content)) {
      if (!tags.length) {
        currentSection = content;
      }
      continue;
    }

    const item = parseItemLine(content, tags, currentSection, globalSettings);
    if (item) items.push(item);
  }

  return { items, globalSettings };
}

function reconstructRawTextFromItems(items, globalSettings = defaultGlobalSettings()) {
  const lines = [];
  const tags = [];
  if (globalSettings.randomOrder) tags.push("[random]");
  if (globalSettings.responseMode === "choice") {
    tags.push(globalSettings.randomChoice ? "[random choice]" : "[choice]");
  } else if (globalSettings.responseMode === "number") {
    tags.push("[number]");
  }
  if (globalSettings.online?.enabled) tags.push("[game start online]");
  if (tags.length) {
    lines.push(tags.join(" ") + (globalSettings.online?.raw ? ` ${globalSettings.online.raw}` : ""));
  }

  let lastSection = null;
  for (const item of items || []) {
    if (item.section && item.section !== lastSection) {
      lines.push(item.section);
      lastSection = item.section;
    }

    const itemTags = Array.isArray(item.tags) && item.tags.length ? item.tags.map(t => `[${t}]`).join(" ") + " " : "";
    if (item.mode === "choice") {
      const options = (item.options || []).map(o => `${o.correct ? "!" : ""}${o.text}`).join(",");
      lines.push(`${itemTags}${item.question}=${options}`);
    } else if (item.mode === "number") {
      lines.push(`${itemTags}${item.question}=${(item.answers || []).join(",")}`);
    } else {
      lines.push(`${itemTags}${item.question}=${(item.answers || []).join(",")}`);
    }
  }

  return lines.join("\n");
}

function shuffle(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function setCookie(name, value, days = 3650) {
  document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${days * 24 * 60 * 60}; SameSite=Lax`;
}

function getCookie(name) {
  const parts = document.cookie ? document.cookie.split("; ") : [];
  for (const part of parts) {
    const idx = part.indexOf("=");
    const key = idx >= 0 ? part.slice(0, idx) : part;
    if (key === name) return decodeURIComponent(idx >= 0 ? part.slice(idx + 1) : "");
  }
  return "";
}

function safeLocalGet(key) {
  try { return localStorage.getItem(key); } catch { return null; }
}

function safeLocalSet(key, value) {
  try { localStorage.setItem(key, value); } catch {}
}

function loadMyList() {
  try {
    const raw = safeLocalGet(MY_KEY);
    const list = raw ? JSON.parse(raw) : [];
    return Array.isArray(list) ? list : [];
  } catch {
    return [];
  }
}

function saveMyList(list) {
  safeLocalSet(MY_KEY, JSON.stringify(list.slice(0, 50)));
}

function loadAccessList() {
  try {
    const raw = safeLocalGet(ACCESS_KEY);
    const list = raw ? JSON.parse(raw) : [];
    return Array.isArray(list) ? list : [];
  } catch {
    return [];
  }
}

function saveAccessList(list) {
  safeLocalSet(ACCESS_KEY, JSON.stringify(list.slice(0, 50)));
}

function findAccessRecord(id) {
  return loadAccessList().find(v => v.id === id) || null;
}

function rememberAccess(id, key, meta = {}) {
  if (!id || !key) return;
  const list = loadAccessList();
  const next = {
    id,
    key,
    title: String(meta.title || ""),
    subtitle: String(meta.subtitle || ""),
    createdAt: Number(meta.createdAt || Date.now()),
    updatedAt: Number(meta.updatedAt || Date.now())
  };

  const idx = list.findIndex(v => v.id === id);
  if (idx >= 0) list[idx] = { ...list[idx], ...next };
  else list.unshift(next);

  list.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
  saveAccessList(list);
}

function removeAccessRecord(id) {
  const next = loadAccessList().filter(v => v.id !== id);
  saveAccessList(next);
}

function upsertMyMeta(meta) {
  const list = loadMyList();
  const id = String(meta?.id || "");
  if (!id) return;

  const next = {
    id,
    title: String(meta.title || ""),
    subtitle: String(meta.subtitle || ""),
    createdAt: Number(meta.createdAt || Date.now()),
    updatedAt: Number(meta.updatedAt || Date.now())
  };

  const idx = list.findIndex(v => v.id === id);
  if (idx >= 0) list[idx] = { ...list[idx], ...next };
  else list.unshift(next);

  list.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
  saveMyList(list);
}

function removeMyMeta(id) {
  const next = loadMyList().filter(v => v.id !== id);
  saveMyList(next);
}

function normalizeTs(value) {
  if (typeof value === "number") return value;
  if (!value) return null;
  if (typeof value.toDate === "function") {
    const d = value.toDate();
    return d instanceof Date ? d.getTime() : null;
  }
  if (typeof value.seconds === "number") {
    return value.seconds * 1000 + Math.floor((value.nanoseconds || 0) / 1e6);
  }
  return null;
}

function formatMinute(value) {
  const ts = normalizeTs(value);
  if (!ts) return "—";
  const d = new Date(ts);
  const pad = n => String(n).padStart(2, "0");
  return `${d.getFullYear()}/${pad(d.getMonth() + 1)}/${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function applySystemTheme() {
  document.body.classList.toggle("dark", !!(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches));
}

function clearResultEnterHandler() {
  if (resultEnterHandler) {
    window.removeEventListener("keydown", resultEnterHandler);
    resultEnterHandler = null;
  }
}

function enableResultEnterHandler() {
  clearResultEnterHandler();
  const isDesktop = window.matchMedia && window.matchMedia("(pointer:fine)").matches && window.innerWidth >= 700;
  if (!isDesktop) return;

  resultEnterHandler = (e) => {
    if (e.key !== "Enter") return;
    const active = document.activeElement;
    if (active && (active.tagName === "INPUT" || active.tagName === "TEXTAREA")) return;
    e.preventDefault();
    nextQuestion();
  };

  window.addEventListener("keydown", resultEnterHandler);
}

function basePath() {
  const p = location.pathname;
  if (p.endsWith("/")) return p;
  const i = p.lastIndexOf("/");
  return i >= 0 ? p.slice(0, i + 1) : "/";
}

function prettyLink(id) {
  return `${location.origin}${basePath()}#/${encodeURIComponent(id)}`;
}

function route() {
  const raw = location.hash.replace(/^#/, "");
  const parts = raw.split("/").filter(Boolean);
  if (!parts.length) return { name: "home" };
  if (parts[0] === "create") return { name: "create" };
  if (parts[0] === "edit" && parts[1]) return { name: "edit", id: decodeURIComponent(parts[1]) };
  return { name: "quiz", id: decodeURIComponent(parts[0]) };
}

function getCommentToken() {
  let token = safeLocalGet(COMMENT_TOKEN_KEY);
  if (!token) {
    token = uid();
    safeLocalSet(COMMENT_TOKEN_KEY, token);
  }
  return token;
}

function getCommentName() {
  const n = safeLocalGet(COMMENT_NAME_KEY);
  if (!n) {
    safeLocalSet(COMMENT_NAME_KEY, "匿名");
    return "匿名";
  }
  return n;
}

function setCommentName(name) {
  safeLocalSet(COMMENT_NAME_KEY, name || "匿名");
}

function sortComments(comments) {
  return (comments || []).slice().sort((a, b) => (normalizeTs(b.createdAt) || 0) - (normalizeTs(a.createdAt) || 0));
}

function canViewComment(comment) {
  if (!comment?.isPrivate) return true;
  if (!state.doc) return false;
  if (state.accessMode === "owner" || state.accessMode === "open" || state.accessMode === "key") return true;
  return comment.authorToken && comment.authorToken === getCommentToken();
}

function canManageComment(comment) {
  if (!comment) return false;
  if (!state.doc) return false;
  if (state.accessMode === "owner" || state.accessMode === "open" || state.accessMode === "key") return true;
  return comment.authorToken && comment.authorToken === getCommentToken();
}

function refreshCommentDraftDefaults() {
  if (!state.commentDraft) {
    state.commentDraft = {
      name: getCommentName(),
      text: "",
      isPrivate: false
    };
    return;
  }
  if (!state.commentDraft.name) state.commentDraft.name = getCommentName();
}

function setAccessModeForDoc(docData, id) {
  if (docData.keyMode === "open") {
    state.accessMode = isOwner() ? "owner" : "open";
    return;
  }
  if (isOwner()) {
    state.accessMode = "owner";
    return;
  }
  const rec = findAccessRecord(id);
  if (rec && docData.key && rec.key === docData.key) {
    state.accessMode = "key";
    return;
  }
  state.accessMode = "none";
}

function isOwner() {
  return !!(state.doc?.ownerToken && getCookie(OWNER_COOKIE) === state.doc.ownerToken);
}

function canEdit() {
  if (!state.doc) return false;
  if (state.doc.keyMode === "open") return true;
  return state.accessMode === "owner" || state.accessMode === "key";
}

function currentQuestion() {
  if (!state.doc?.items?.length) return null;
  const idx = state.quiz.order[state.quiz.index];
  if (idx === undefined) return null;
  return { idx, item: state.doc.items[idx] };
}

function currentScoreMeta() {
  const total = state.quiz.order.length || (state.doc?.items?.length || 0);
  const correctCount = Object.values(state.quiz.attempts || {}).filter(v => v.correct).length;
  return { correctCount, total, label: `${correctCount}/${total}` };
}

function blankDraft() {
  return { title: "", subtitle: "", rawText: "", keyMode: "key", key: "" };
}

function topButtonHtml() {
  return `<button class="ghost" id="topBtn">トップ</button>`;
}

function editorActionHtml() {
  const buttons = [];
  if (state.doc) {
    if (state.accessMode === "owner") {
      buttons.push(`<button class="danger" id="deleteBtn">削除</button>`);
    } else if (state.accessMode === "key") {
      buttons.push(`<button class="danger" id="leaveBtn">脱退</button>`);
    }
  }
  buttons.push(`<button class="primary" id="saveBtn">保存</button>`);
  return buttons.join("");
}

function openEditFromDoc() {
  state.draft = {
    title: state.doc?.title || "",
    subtitle: state.doc?.subtitle || "",
    rawText: state.doc?.rawText || reconstructRawTextFromItems(state.doc?.items || [], state.doc?.globalSettings || defaultGlobalSettings()),
    keyMode: state.doc?.keyMode || "key",
    key: state.doc?.key || ""
  };
  state.screen = "editor";
  render();
}

function startQuiz(docData, id, orderIndices = null, onlyWrong = false) {
  state.doc = {
    ...docData,
    comments: sortComments(docData.comments || [])
  };
  state.docId = id;
  setAccessModeForDoc(state.doc, id);
  state.showComments = false;
  refreshCommentDraftDefaults();

  if (state.accessMode === "key") {
    rememberAccess(id, docData.key, {
      title: docData.title || "",
      subtitle: docData.subtitle || "",
      createdAt: normalizeTs(docData.createdAt) || Date.now(),
      updatedAt: normalizeTs(docData.updatedAt) || Date.now()
    });
  }

  if (state.accessMode === "owner") {
    upsertMyMeta({
      id,
      title: docData.title || "",
      subtitle: docData.subtitle || "",
      createdAt: normalizeTs(docData.createdAt) || Date.now(),
      updatedAt: normalizeTs(docData.updatedAt) || Date.now()
    });
  }

  const allIndices = (docData.items || []).map((_, i) => i);
  const order = Array.isArray(orderIndices)
    ? orderIndices.slice()
    : (docData.globalSettings?.randomOrder ? shuffle(allIndices) : allIndices);

  state.quiz = {
    phase: "question",
    order,
    index: 0,
    typedAnswer: "",
    lastResult: null,
    attempts: {},
    onlyWrong: !!onlyWrong,
    selectedChoice: ""
  };

  state.screen = "quiz";
  document.title = docData.title ? `${docData.title} | 問題作成サイト` : "問題作成サイト";
  render();
}

function restartQuiz() {
  if (!state.doc) return;
  if (state.quiz.onlyWrong) {
    startQuiz(state.doc, state.docId, state.quiz.order, true);
  } else {
    startQuiz(state.doc, state.docId, null, false);
  }
}

function startWrongOnlyQuiz() {
  if (!state.doc) return;
  const wrong = state.quiz.order.filter(idx => !state.quiz.attempts[idx]?.correct);
  if (!wrong.length) {
    alert("間違えた問題がないよ");
    return;
  }
  startQuiz(state.doc, state.docId, wrong, true);
}

function nextQuestion() {
  state.quiz.index += 1;
  state.quiz.typedAnswer = "";
  state.quiz.lastResult = null;
  state.quiz.selectedChoice = "";
  state.quiz.phase = state.quiz.index >= state.quiz.order.length ? "done" : "question";
  render();
}

function submitAnswer() {
  const q = currentQuestion();
  if (!q) return;

  let given = state.quiz.typedAnswer;
  if (q.item.mode === "choice") {
    given = state.quiz.selectedChoice;
  }

  if (!String(given || "").trim()) {
    alert("答えを入れてね");
    return;
  }

  let correct = false;
  if (q.item.mode === "number") {
    const cleanGiven = normalizeNumberText(given);
    correct = (q.item.answers || []).some(ans => normalizeNumberText(ans) === cleanGiven);
  } else if (q.item.mode === "choice") {
    const chosen = norm(given);
    const correctOptions = (q.item.options || []).filter(o => o.correct).map(o => norm(o.text));
    correct = correctOptions.includes(chosen);
  } else {
    const normalizedGiven = norm(given);
    const normalizedAnswers = (q.item.answers || []).map(norm);
    correct = normalizedAnswers.includes(normalizedGiven);
  }

  state.quiz.attempts[q.idx] = { given, correct };
  state.quiz.lastResult = { idx: q.idx, given, correct };
  state.quiz.phase = "result";
  render();
}

function syncEditorArea(textarea, gutter) {
  const minHeight = 420;
  textarea.style.height = "auto";
  const next = Math.max(minHeight, textarea.scrollHeight);
  textarea.style.height = `${next}px`;
  gutter.style.height = `${next}px`;

  const count = Math.max(1, textarea.value.split(/\r?\n/).length + 1);
  gutter.textContent = Array.from({ length: count }, (_, i) => i + 1).join("\n");
}

async function persistComments(nextComments) {
  if (!state.docId) return;
  const sorted = sortComments(nextComments);
  const updatedAt = Date.now();

  await setDoc(doc(db, COLLECTION, state.docId), {
    comments: sorted,
    updatedAt
  }, { merge: true });

  state.doc.comments = sorted;
  state.doc.updatedAt = updatedAt;

  if (state.accessMode === "owner") {
    upsertMyMeta({
      id: state.docId,
      title: state.doc.title || "",
      subtitle: state.doc.subtitle || "",
      createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
      updatedAt
    });
  }

  if (state.accessMode === "key") {
    rememberAccess(state.docId, state.doc.key || "", {
      title: state.doc.title || "",
      subtitle: state.doc.subtitle || "",
      createdAt: normalizeTs(state.doc.createdAt) || Date.now(),
      updatedAt
    });
  }

  render();
}

function openDeleteConfirmThenDelete() {
  if (!state.docId) return;

  const title = state.doc?.title || state.draft?.title || "";
  const typed = prompt(`削除するには、タイトル「${title}」をそのまま入力してね`, "");
  if (typed === null) return;
  if (typed.trim() !== title.trim()) {
    alert("タイトルが違うから削除をやめたよ");
    return;
  }

  if (!confirm(`本当に「${title}」を削除する？\nこの操作は戻せないよ。`)) return;

  const btn = document.getElementById("deleteBtn");
  if (btn) btn.disabled = true;

  (async () => {
    try {
      await deleteDoc(doc(db, COLLECTION, state.docId));
      removeMyMeta(state.docId);
      removeAccessRecord(state.docId);
      state.docId = "";
      state.doc = null;
      state.draft = null;
      state.accessMode = "none";
      state.showComments = false;
      location.hash = "";
      alert("削除したよ");
      render();
    } catch (err) {
      console.error("delete failed:", err);
      alert(`削除で失敗したよ: ${err?.message || err}`);
    } finally {
      if (btn) btn.disabled = false;
    }
  })();
}

function openLeaveConfirmThenLeave() {
  if (!state.docId) return;
  if (!confirm("本当に共同編集から脱退しますか？")) return;
  removeAccessRecord(state.docId);
  state.accessMode = "none";
  alert("脱退したよ");
  render();
}

function openCommentToggle() {
  state.showComments = !state.showComments;
  render();
}

function insertComposerText(textarea, insertText, ctx) {
  const value = textarea.value;
  const start = ctx?.start ?? textarea.selectionStart ?? value.length;
  const end = ctx?.end ?? textarea.selectionEnd ?? value.length;
  const next = value.slice(0, start) + insertText + value.slice(end);
  textarea.value = next;
  state.commentDraft.text = next;
  const pos = start + insertText.length;
  textarea.selectionStart = textarea.selectionEnd = pos;
  textarea.focus();
  textarea.dispatchEvent(new Event("input", { bubbles: true }));
}

function analyzeComposerTrigger(text, cursor) {
  const before = String(text ?? "").slice(0, cursor);
  const lastBreak = Math.max(
    before.lastIndexOf("\n"),
    before.lastIndexOf(" "),
    before.lastIndexOf("\t"),
    before.lastIndexOf("　")
  );
  const segment = before.slice(lastBreak + 1);
  if (!segment.startsWith("@") && !segment.startsWith("#")) return null;
  return {
    trigger: segment[0],
    start: lastBreak + 1,
    end: cursor,
    query: segment.slice(1)
  };
}

function getComposerSuggestions(ctx) {
  if (!ctx) return [];
  if (ctx.trigger === "@" && state.quiz.onlyWrong) return [];
  if (ctx.trigger === "@") {
    return [{ label: "点数", insert: "[[SCORE]]" }];
  }
  if (ctx.trigger === "#") {
    const q = String(ctx.query || "").toLowerCase().trim();
    const items = COMMENT_TAG_SUGGESTIONS
      .filter(v => !q || v.toLowerCase().includes(q))
      .map(v => ({ label: v, insert: v }));
    return items.length ? items : COMMENT_TAG_SUGGESTIONS.map(v => ({ label: v, insert: v }));
  }
  return [];
}

function renderCommentBody(comment) {
  const raw = String(comment?.text ?? "");
  const hasScore = comment?.scoreCorrect != null && comment?.scoreTotal != null && raw.includes("[[SCORE]]");
  const badge = hasScore ? `<span class="scoreToken">${esc(`${comment.scoreCorrect}/${comment.scoreTotal}`)}</span>` : "";
  return raw
    .split("[[SCORE]]")
    .map((part, idx, arr) => {
      const body = escBr(part);
      return body + (idx < arr.length - 1 ? badge : "");
    })
    .join("");
}

function commentRoleLabel(role) {
  if (role === "owner") return "主催者";
  if (role === "editor") return "共同編集者";
  return "コメント";
}

function commentRoleClass(role) {
  if (role === "owner") return "commentOwner";
  if (role === "editor") return "commentEditor";
  return "commentViewer";
}

function renderCommentsPanel(comments) {
  const hiddenCount = comments.filter(c => c.isPrivate && !canViewComment(c)).length;
  const visibleComments = comments.filter(c => canViewComment(c));

  const list = visibleComments.length ? visibleComments.map(comment => {
    const role = comment.authorRole || "viewer";
    const roleLabel = commentRoleLabel(role);
    const roleClass = commentRoleClass(role);
    const canManage = canManageComment(comment);

    if (!canViewComment(comment)) {
      return `
        <div class="commentItem">
          <div class="commentMask">🫥 非公開コメント</div>
        </div>
      `;
    }

    return `
      <div class="commentItem ${roleClass}">
        <div class="reviewQ">${esc(comment.authorName || "匿名")} <span class="commentBadge">${esc(roleLabel)}</span> <span class="commentBadge">${comment.isPrivate ? "🫥 非公開" : "公開"}</span></div>
        <div class="metaLine">${esc(formatMinute(comment.createdAt))}</div>
        <div class="commentBody">${renderCommentBody(comment)}</div>
        <div class="row" style="justify-content:flex-end;">
          ${canManage ? `<button class="ghost miniAction" data-toggle-comment="${esc(comment.id)}">公開/非公開</button>` : ""}
          ${canManage ? `<button class="danger miniAction" data-delete-comment="${esc(comment.id)}">削除</button>` : ""}
        </div>
      </div>
    `;
  }).join("") : `<div class="note">まだコメントはないよ。</div>`;

  const hiddenNote = hiddenCount > 0 ? `<span class="commentBadge">🫥 ${hiddenCount}</span>` : "";

  return `
    <div class="commentWrap">
      <div class="card commentWrap">
        <div class="commentHeader">
          <div class="label" style="font-size:14px">コメントを書く</div>
          <div class="commentPrivateNote">@で点数、#で候補</div>
        </div>

        <div class="commentForm">
          <div>
            <div class="label">名前（任意）</div>
            <input id="commentName" class="input" type="text" placeholder="匿名でもOK" value="${esc(state.commentDraft?.name || getCommentName())}">
          </div>

          <div>
            <div class="label">コメント</div>
            <textarea id="commentText" class="textarea" style="min-height:120px;overflow:hidden;" placeholder="感想やメモを書いてね">@ や # を入れると候補が出るよ</textarea>
          </div>

          <div id="commentSuggestionPanel" class="suggestionPanel"></div>

          <div class="row" style="justify-content:space-between;align-items:center;">
            <label class="row" style="gap:8px;cursor:pointer;">
              <input id="commentPrivate" type="checkbox" ${state.commentDraft?.isPrivate ? "checked" : ""} />
              <span>非公開にする</span>
            </label>
            <button class="primary" id="postCommentBtn">コメントする</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="commentHeader">
          <div class="label" style="font-size:14px">コメント一覧</div>
          <div class="commentToggleRow">
            <span class="commentBadge">表示 ${visibleComments.length}</span>
            ${hiddenNote}
          </div>
        </div>
        <div class="reviewList">
          ${list}
        </div>
      </div>
    </div>
  `;
}

async function addComment() {
  if (!state.docId || !state.doc) return;

  const name = (state.commentDraft?.name || getCommentName()).trim() || "匿名";
  let text = (state.commentDraft?.text || "").trim();
  const isPrivate = !!state.commentDraft?.isPrivate;
  if (!text) {
    alert("コメントを書いてね");
    return;
  }

  const role = state.accessMode === "owner"
    ? "owner"
    : (state.accessMode === "key" || state.accessMode === "open" ? "editor" : "viewer");

  let scoreCorrect = null;
  let scoreTotal = null;

  if (!state.quiz.onlyWrong && text.includes("[[SCORE]]")) {
    const score = currentScoreMeta();
    scoreCorrect = score.correctCount;
    scoreTotal = score.total;
  } else if (state.quiz.onlyWrong) {
    text = text.replace(/\[\[SCORE\]\]/g, "");
  }

  const comment = {
    id: uid(),
    authorToken: getCommentToken(),
    authorName: name,
    authorRole: role,
    text,
    isPrivate,
    createdAt: Date.now(),
    updatedAt: Date.now(),
    scoreCorrect,
    scoreTotal
  };

  setCommentName(name);

  const next = sortComments([...(state.doc.comments || []), comment]);
  await persistComments(next);

  state.commentDraft.text = "";
  state.commentDraft.isPrivate = false;
  state.commentDraft.name = name;
  state.showComments = true;
  render();
}

async function toggleCommentVisibility(commentId) {
  if (!state.doc?.comments?.length) return;
  const next = state.doc.comments.map(c => c.id === commentId ? { ...c, isPrivate: !c.isPrivate, updatedAt: Date.now() } : c);
  await persistComments(next);
  state.showComments = true;
  render();
}

async function deleteComment(commentId) {
  if (!state.doc?.comments?.length) return;
  if (!confirm("このコメントを削除する？")) return;
  const next = state.doc.comments.filter(c => c.id !== commentId);
  await persistComments(next);
  state.showComments = true;
  render();
}

