saveBtn.addEventListener("click", async () => {
  console.log("save click start");

  try {
    console.log("before setDoc");
    await setDoc(doc(db, COLLECTION, newDocId), payload, { merge: true });
    console.log("after setDoc");
    alert("保存できたよ");
  } catch (err) {
    console.error("setDoc failed:", err);
    alert("保存で失敗したよ");
  } finally {
    console.log("save click end");
    saveBtn.disabled = false;
    saveBtn.textContent = "保存";
  }
});
